# 直接复用 countdown 的 MySQL 用户和 countdown 数据库。
# 用户名、密码与 countdown 服务器部署目录 .env 中的 MYSQL_USER/MYSQL_PASSWORD 相同。
COUNTDOWN_DATABASE_URL=mysql://countdown:replace_with_existing_password@countdown-mysql:3306/countdown

# npm run ops:hash-password -- '你的强密码'
# Argon2 哈希含有 $，Compose .env 中务必使用单引号包住整个值。
OPS_ADMIN_USERNAME=admin
OPS_ADMIN_PASSWORD_HASH='$argon2id$v=19$replace_with_generated_hash'
OPS_SESSION_SECRET=replace_with_openssl_rand_base64_48

# 独立 APK 下载页 /countdown/download 的服务端口令；不要使用示例值。
APK_DOWNLOAD_ACCESS_KEY=replace_with_shared_download_key
APK_DOWNLOAD_MAX_FAILURES=5
APK_DOWNLOAD_WINDOW_MINUTES=15
APK_DOWNLOAD_LOCK_MINUTES=60
APK_DOWNLOAD_SESSION_DAYS=7

# GitHub fine-grained PAT：只授权 countdown 仓库，Actions 读写、Contents 只读。
OPS_GITHUB_TOKEN=github_pat_replace_me
OPS_GITHUB_OWNER=YourSigh
OPS_GITHUB_REPOSITORY=countdown
OPS_GITHUB_REF=main

COUNTDOWN_RELEASES_DIR=/docker/countdown/releases
COUNTDOWN_DEPLOY_QUEUE_DIR=/docker/countdown/deploy-queue
DEPLOY_WEBHOOK_SECRET=replace_with_openssl_rand_base64_48
OPS_COUNTDOWN_HEALTH_URL=http://countdown-api:4000/health
OPS_LOGIN_MAX_FAILURES=5
OPS_LOGIN_WINDOW_MINUTES=15
OPS_LOGIN_LOCK_MINUTES=60
OPS_SESSION_HOURS=12
